# 服务器配置
PORT=3000
NODE_ENV=development

# PostgreSQL 数据库
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pet_platform
DB_USER=postgres
DB_PASSWORD=postgres

# MongoDB (日志和非结构化数据)
MONGODB_URI=mongodb://localhost:27017/pet_platform_logs

# Redis 缓存
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# 文件上传
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# 邮件服务 (可选)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-password

# 支付配置 (可选)
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_KEY=

ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# 第三方 API (可选)
MAPS_API_KEY=
SMS_API_KEY=
